{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "NODE_NO_WARNINGS=1 node .claude/hooks/format-frontend.mjs",
            "timeout": 30,
            "statusMessage": "Formatting frontend with Prettier…"
          }
        ]
      }
    ]
  }
}
